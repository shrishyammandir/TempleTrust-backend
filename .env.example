# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/templetrust
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/templetrust

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# UPI Configuration
UPI_ID=trustname@ybl
TRUST_NAME=Your Temple Trust Name

# JWT Secret (generate a random string)
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

# Email Configuration (Using Gmail SMTP as example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=Your Temple Trust <your-email@gmail.com>

# Admin Email (receives donation notifications)
ADMIN_EMAIL=admin@templetrust.org

# Trust Details
TRUST_REGISTRATION_NO=TRUST/2020/123456
TRUST_80G_NO=80G/2020/123456
TRUST_PAN=AAACT1234F
TRUST_ADDRESS=Temple Address Line 1, City, State - Pincode
TRUST_PHONE=+91-1234567890
TRUST_EMAIL=info@templetrust.org
TRUST_WEBSITE=https://templetrust.org

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./public/uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_here
